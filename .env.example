# ─────────────────────────────────────────────
#  Akash Portfolio — Environment Variables
#  Copy this to .env — NEVER commit .env to Git
# ─────────────────────────────────────────────

PORT=5000
NODE_ENV=development

# Your deployed Render URL (set this after you deploy)
CLIENT_ORIGIN=https://your-app-name.onrender.com

# Formspree form ID (from formspree.io — safe to keep server-side)
# formspree.io → New Form → copy the ID from the endpoint URL
# e.g. https://formspree.io/f/xpwzgkla → ID is: xpwzgkla
FORMSPREE_ID=your_formspree_id_here

# Optional: GitHub token to avoid API rate limits
GITHUB_TOKEN=
